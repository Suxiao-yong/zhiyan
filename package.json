    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-sql": "^2.4.0",
    "echarts": "^6.1.0",
    "element-plus": "^2.14.2",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.5",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
